# API HTTP agregada (RouterBOARD); desligada por padrao — mapa na UI e o SQLite.
NETWATCH_API_ENABLED=false
NETWATCH_API_TIMEOUT_MS=10000
NETWATCH_SQLITE_PATH=.data/netwatch.sqlite

# Docker Compose: caminho absoluto *dentro do container* onde o volume nomeado e montado.
# Tem de ser o diretorio-pai do ficheiro SQLite (com cwd /app no container).
# Ex.: NETWATCH_SQLITE_PATH=.data/netwatch.sqlite  ->  NETWATCH_DOCKER_PERSIST_DIR=/app/.data
# Se mudar NETWATCH_SQLITE_PATH para outra pasta (ex. storage/db.sqlite), atualize esta variavel
# para /app/storage e mantenha coerente com docker-compose.*.yaml (ou perde-se dados ao reiniciar).
NETWATCH_DOCKER_PERSIST_DIR=/app/.data

# Cadastro/edicao/remocao de servidores na tela de login. Vazio = sem bloqueio (dev).
# Header: X-Netwatch-Server-Registry-Secret (ou Bearer). Ver README checklist em producao.
# NETWATCH_SERVER_REGISTRY_SECRET=
# Concorrencia de pings no GET /api/devices/status (1-64, padrao 12)
NETWATCH_STATUS_PING_CONCURRENCY=12

# Sessao: memory (padrao) ou redis (varias instancias + mesmo Redis)
# NETWATCH_SESSION_BACKEND=redis
# NETWATCH_REDIS_URL=redis://localhost:6379

# TTL da sessao em ms (padrao 8h)
# NETWATCH_SESSION_TTL_MS=28800000

# Rate limit (por IP). Com NETWATCH_REDIS_URL, contadores sao globais no cluster.
# NETWATCH_RATE_LIMIT_LOGIN_MAX=20
# NETWATCH_RATE_LIMIT_LOGIN_WINDOW_MS=60000
# NETWATCH_RATE_LIMIT_STATUS_MAX=120
# NETWATCH_RATE_LIMIT_STATUS_WINDOW_MS=60000
# NETWATCH_RATE_LIMIT_SERVERS_POST_MAX=30
# NETWATCH_RATE_LIMIT_SERVERS_POST_WINDOW_MS=60000
