# Defaults para Docker em desenvolvimento (ver README, secao Docker).
# - Carregado pelo Compose como `env_file` do servico (variaveis dentro do container).
# - Use `npm run docker:dev` (ou `docker compose --env-file .env.docker.dev ...`) para o Compose
#   interpolar `NETWATCH_DOCKER_PERSIST_DIR` na linha do volume.
# - Para sobrescrever: crie `.env` na raiz (opcional); o Compose mescla e `.env` ganha para chaves repetidas.
# Nao coloque segredos aqui; use `.env` (gitignored).

NETWATCH_API_ENABLED=false
NETWATCH_API_TIMEOUT_MS=10000
NETWATCH_SQLITE_PATH=.data/netwatch.sqlite
NETWATCH_STATUS_PING_CONCURRENCY=12
NETWATCH_DOCKER_PERSIST_DIR=/app/.data
WATCHPACK_POLLING=true
